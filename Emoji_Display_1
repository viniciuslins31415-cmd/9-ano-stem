// 😎 Óculos
void emojiOculos() {

  display.clearDisplay();

  display.drawCircle(64, 32, 25, WHITE);

  display.fillRect(45, 20, 15, 10, WHITE);
  display.fillRect(68, 20, 15, 10, WHITE);

  display.drawLine(60, 25, 68, 25, WHITE);

  display.drawLine(54, 40, 64, 46, WHITE);
  display.drawLine(64, 46, 74, 40, WHITE);

  display.display();
}

// 😮 Surpreso
void emojiSurpreso() {

  display.clearDisplay();
      
  display.drawCircle(64, 32, 25, WHITE);

  display.fillCircle(54, 24, 3, WHITE);
  display.fillCircle(74, 24, 3, WHITE);

  display.drawCircle(64, 42, 6, WHITE);

