// 😴 Dormindo
void emojiDormindo() {

  display.clearDisplay();

  display.drawCircle(64, 32, 25, WHITE);

  display.drawLine(48, 24, 58, 24, WHITE);
  display.drawLine(70, 24, 80, 24, WHITE);

  display.drawCircle(64, 42, 5, WHITE);

  display.setTextSize(2);
  display.setCursor(90, 10);
  display.print("Z");

  display.display();
}

// ❤️ Coração
void coracao() {

  display.clearDisplay();

  display.fillCircle(54, 24, 10, WHITE);
  display.fillCircle(74, 24, 10, WHITE);

  display.fillTriangle(44, 30, 84, 30, 64, 55, WHITE);

  display.display();
}

// 🔥 Fogo
void fogo() {

  display.clearDisplay();

  display.fillTriangle(64, 10, 40, 50, 88, 50, WHITE);

  display.fillTriangle(64, 20, 50, 50, 78, 50, BLACK);

  display.display();
}

// ⭐ Estrela
void estrela() {

  display.clearDisplay();

  display.drawLine(64, 10, 70, 28, WHITE);
  display.drawLine(70, 28, 90, 28, WHITE);
  display.drawLine(90, 28, 74, 40, WHITE);
  display.drawLine(74, 40, 80, 58, WHITE);
  display.drawLine(80, 58, 64, 48, WHITE);
  display.drawLine(64, 48, 48, 58, WHITE);
  display.drawLine(48, 58, 54, 40, WHITE);
  display.drawLine(54, 40, 38, 28, WHITE);
  display.drawLine(38, 28, 58, 28, WHITE);
  display.drawLine(58, 28, 64, 10, WHITE);

  display.display();
}

// ================= CALLBACK BLE =================

class MeuCallback: public BLECharacteristicCallbacks {

  void onWrite(BLECharacteristic *pCharacteristic) {

    recebido = pCharacteristic->getValue();

    Serial.println(recebido);

    if(recebido == "feliz") {
      emojiFeliz();
    }

    else if(recebido == "triste") {
      emojiTriste();
    }

    else if(recebido == "neutro") {
      emojiNeutro();
    }

    else if(recebido == "oculos") {
      emojiOculos();
    }

    else if(recebido == "surpreso") {
      emojiSurpreso();
    }

    else if(recebido == "sono") {
      emojiDormindo();
    }

    else if(recebido == "amor") {
      coracao();
    }

    else if(recebido == "fogo") {
      fogo();
    }

    else if(recebido == "estrela") {
      estrela();
    }
  }
};

// ================= SETUP =================

void setup() {

  Serial.begin(115200);

  Wire.begin(21, 22);

  if(!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {

    Serial.println("OLED nao encontrado");

    while(true);
  }

  display.clearDisplay();

  display.setTextSize(2);
  display.setTextColor(WHITE);
  display.setCursor(10, 20);
  display.println("ESP32");
  display.display();

  // BLE
  BLEDevice::init("PainelEmoji");

  BLEServer *pServer = BLEDevice::createServer();

  BLEService *pService = pServer->createService(SERVICE_UUID);

  pCharacteristic = pService->createCharacteristic(
                      CHARACTERISTIC_UUID,
                      BLECharacteristic::PROPERTY_WRITE
                    );

  pCharacteristic->setCallbacks(new MeuCallback());

  pService->start();

  BLEAdvertising *pAdvertising = BLEDevice::getAdvertising();

  pAdvertising->start();

  Serial.println("Bluetooth pronto!");
}

// ================= LOOP =================

void loop() {

}
